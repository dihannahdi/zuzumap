# Kafilah configuration.
# In production this is provided to systemd via EnvironmentFile (/opt/kafilah/.env).
# For local dev, copy to .env and run `cargo run`.

# Shared group secret. Everyone in the circle uses this key.
# Generate a strong one: `openssl rand -base64 24`
APP_KEY=change-me-to-a-long-random-secret

# Loopback address the binary listens on (Apache reverse-proxies /api here).
BIND_ADDR=127.0.0.1:8795

# SQLite database file (created on first run).
# Prod: /opt/kafilah/data/kafilah.db   Dev: ./data/kafilah.db
DB_PATH=./data/kafilah.db

# Static frontend directory (only used when the binary serves static itself,
# e.g. local dev). In prod Apache serves the docroot and this is a harmless fallback.
# Prod: /www/wwwroot/map.nahdi.space   Dev: ./static
STATIC_DIR=./static
